# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral

# Database Configuration
DATABASE_URL=sqlite:///./fireform.db

# Logging Configuration
LOG_LEVEL=INFO

# Security Configuration
